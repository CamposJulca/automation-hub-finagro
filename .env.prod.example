# ── Copia este archivo como .env.prod y ajusta los valores ───────────────────

# ============================================
# Django
# ============================================
# OBLIGATORIO cambiar antes de arrancar en producción.
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion-debe-tener-50-caracteres
DEBUG=False
# Hosts permitidos para responder requests. Lista separada por comas.
# En producción debe ser restrictivo a los dominios reales del despliegue.
ALLOWED_HOSTS=automation-hub-finagro.ngrok.io,localhost,127.0.0.1

# ============================================
# Base de datos PostgreSQL
# ============================================
# Flag booleano (no URL): cualquier valor truthy activa PostgreSQL usando
# las DB_* de abajo. Si se omite o se deja vacío, Django cae a SQLite local.
# Deuda futura: renombrar a USE_DATABASE_URL / USE_POSTGRES para que el
# nombre refleje lo que el código hace.
DATABASE_URL=true
DB_NAME=automation_hub
DB_USER=postgres
DB_PASSWORD=postgres_seguro_2026
DB_HOST=db
DB_PORT=5432

# ============================================
# CORS — dominios ngrok de producción
# ============================================
CORS_ALLOWED_ORIGINS=https://automation-hub-finagro.ngrok.io,https://facturacion-electronica.ngrok.io,https://gestion-administrativa.ngrok.io,https://mesa-ayuda.ngrok.io

# ============================================
# Microsoft Graph / Azure AD
# Consumido por el container FactIA (comparte este .env.prod vía env_file).
# ============================================
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# ============================================
# Cron interno
# Token que valida llamadas a /api/facturacion/sincronizar-cron/
# (header X-Cron-Token). Debe coincidir con el de FactIA.
# ============================================
CRON_INTERNAL_TOKEN=

# ============================================
# Credenciales script PowerShell de sincronización
# Usuario y password del usuario técnico Django que el endpoint
# /api/facturacion/descargar-script/ inyecta al template del script .ps1
# servido al usuario final autenticado.
# ============================================
PS1_AUTH_USER=
PS1_AUTH_PASS=
